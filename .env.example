APP_NAME=AdGenieHQ
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=replace-with-secure-secret
API_V1_PREFIX=/api/v1

# Founding super-admins, promoted to is_superuser on API startup (grants /admin
# access + bypasses all plan limits). Comma-separated emails; the accounts must
# already exist. Additive + idempotent (never demotes).
#   INITIAL_SUPERUSER_EMAILS=founder@yourdomain.com,ops@yourdomain.com
INITIAL_SUPERUSER_EMAILS=

DATABASE_URL=postgresql+psycopg://adgeniehq:adgeniehq@localhost:5432/adgeniehq_ai
# Optional — separate database for backend tests. If unset, tests fall back to DATABASE_URL with `_test` suffix.
TEST_DATABASE_URL=postgresql+psycopg://adgeniehq:adgeniehq@localhost:5432/adgeniehq_ai_test
REDIS_URL=redis://localhost:6379/0

# Local dev origins. Production (adgeniehq.com) is set in the Render blueprint:
#   CORS_ORIGINS=["https://adgeniehq.com","https://www.adgeniehq.com"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# LLM provider selection. Supported: "openai" (default), "anthropic", "google_ai".
# Workspaces can override per-call with a BYOK credential under Settings → API keys.
LLM_PROVIDER=openai

# OpenAI — GPT-5.4 mini is the default (fast, agentic; supports tools + skills).
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini
# AI creative images (Social studio / content drafts). gpt-image-* returns
# base64 we host ourselves; switch to gpt-image-1 or dall-e-3 if this id is
# rejected. Image generation always uses OpenAI, even if LLM_PROVIDER differs.
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium

# ElevenLabs text-to-speech — a PLATFORM key that narrates the built-in
# Help/Knowledge-Base articles (Help → Audio tab). Not per-workspace. When the
# key or voice id is blank, the Audio tab shows a clean "coming soon" state.
# Voice ids come from the ElevenLabs Voice Library.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=

# S3-compatible object storage (Cloudflare R2, DO Spaces, Wasabi, AWS S3) —
# durable storage for uploaded + AI-generated images. Set access key + secret
# + bucket + endpoint to enable; leave blank to use the local uploads/ dir
# (fine for dev, EPHEMERAL on Render). The older R2_* names are also accepted.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
# Full S3 API endpoint, e.g. https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
# Optional key namespace so several apps can share one bucket, e.g. adgeniehq
S3_PREFIX=
# Optional public base URL (r2.dev subdomain or custom/CDN domain, no trailing
# slash). If blank, derives {endpoint}/{bucket}. Cloudflare R2's S3 endpoint is
# NOT publicly readable, so R2 MUST set this to the r2.dev / custom domain.
S3_PUBLIC_URL=

# Optional faster/cheaper model used ONLY for the large Growth DNA background
# generation (must match the active provider, e.g. claude-haiku-4-5 / gpt-5.4-mini).
LLM_FAST_MODEL=

# Anthropic Claude (recommended). Pick one:
#   claude-opus-4-7   — most capable, highest cost
#   claude-sonnet-4-6 — balanced default (used here)
#   claude-haiku-4-5-20251001 — fastest / cheapest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google AI (Gemini)
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-flash

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

META_APP_ID=
META_APP_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Recurring subscription billing (PayPal) -------------------------------
# PayPal is the sole subscription processor (Paddle was removed). Subscriptions
# activate once CLIENT_ID + CLIENT_SECRET + WEBHOOK_ID are set. Checkout creates
# a subscription server-side and redirects the buyer to PayPal to approve;
# activation is confirmed via the webhook: /api/v1/billing/paypal/webhook
# "sandbox" while testing, "live" in production.
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Optional override; else derived from PAYPAL_ENVIRONMENT
# (sandbox: https://api-m.sandbox.paypal.com).
PAYPAL_API_BASE=
# Webhook id from the PayPal dashboard — used to verify inbound event signatures.
PAYPAL_WEBHOOK_ID=
# Monthly PayPal Billing Plan ids per plan…
PAYPAL_PLAN_ID_STARTER=
PAYPAL_PLAN_ID_PRO=
PAYPAL_PLAN_ID_AGENCY=
# …and the yearly Plan ids (used when the customer picks annual billing).
PAYPAL_PLAN_ID_STARTER_ANNUAL=
PAYPAL_PLAN_ID_PRO_ANNUAL=
PAYPAL_PLAN_ID_AGENCY_ANNUAL=

# --- Fee-collection layer (optional, one-off ad-management fees) -----------
# Separate from subscriptions above. The fee ledger is processor-agnostic;
# "manual" needs no config. PayPal fee invoices reuse the PAYPAL_CLIENT_ID /
# PAYPAL_CLIENT_SECRET / PAYPAL_API_BASE set above.

# Public URLs. Production (adgeniehq.com), set in the Render blueprint:
#   FRONTEND_URL=https://adgeniehq.com
#   BACKEND_URL=https://api.adgeniehq.com
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Frontend (apps/web) — Vite reads VITE_-prefixed vars at BUILD time.
# Production: VITE_API_BASE_URL=https://api.adgeniehq.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=AdGenieHQ

# ---------------------------------------------------------------------------
# Operational / optional (mostly production). All safe to leave blank locally.
# ---------------------------------------------------------------------------

# Background jobs. 1 = dispatch slow work (agent runs, SMTP sends, autopilot
# scans) to the Celery worker; 0 = run inline in the request. Production = 1.
WORKERS_ENABLED=0
# Override only if the broker/result backend should differ from REDIS_URL.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Transactional email (verification, password reset, invites, reports,
# outreach). Transport precedence: Resend → SMTP → log-drop. Read via os.getenv.
#
# Resend (preferred): set RESEND_API_KEY + EMAIL_FROM. EMAIL_FROM's domain must
# be VERIFIED in your Resend account (SPF/DKIM DNS), e.g. "AdGenieHQ <noreply@yourdomain>".
RESEND_API_KEY=
EMAIL_FROM=AdGenieHQ <noreply@adgeniehq.com>
#
# SMTP (fallback): used only when RESEND_API_KEY is unset (or a Resend send
# fails). If neither transport is configured, emails are logged and dropped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@adgeniehq.com
SMTP_TLS=1

# Inbound email parsing for outreach replies (reply+<token>@<domain>).
INBOUND_EMAIL_DOMAIN=
INBOUND_EMAIL_SECRET=

# Website Agent — Google PageSpeed Insights key (raises the PSI rate limit).
PAGESPEED_API_KEY=

# Error monitoring. No-op when blank.
SENTRY_DSN=
